{
  "name": "bank-value-benchmark-mvp",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test:cleanup": "node tests/cleanup-artifacts.mjs",
    "test:bundle-size": "npm run build && node tests/check-bundle-size.mjs",
    "test:load": "k6 run tests/load-test.js",
    "test:tdz": "npm run test:cleanup && npx playwright test tests/tdz-smoke.spec.js --reporter=list",
    "test:tdz-node": "node tests/tdz-diagnostic.mjs",
    "test:build-check": "npm run build && node tests/build-tdz-scanner.mjs",
    "test:circular": "madge src/ --circular",
    "test:duplicates": "jscpd src/ --threshold 5",
    "test:garbage": "node tests/garbage-scanner.mjs",
    "test:visual": "npx playwright test tests/visual.spec.js --reporter=list",
    "test:a11y": "npx playwright test tests/a11y-polish.spec.js --reporter=list",
    "test:quality": "npm run lint && npm run test:circular && npm run test:duplicates && npm run test:garbage && npm run test:a11y",
    "test:lighthouse": "npx playwright test tests/lighthouse.spec.js --reporter=list",
    "prepare": "husky"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "html-to-image": "^1.11.13",
    "ioredis": "^5.10.0",
    "jspdf": "^4.2.0",
    "nodemailer": "^8.0.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-is": "^19.2.4",
    "recharts": "^3.7.0",
    "source-map": "^0.6.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.23",
    "eslint": "^9.39.1",
    "eslint-plugin-better-tailwindcss": "^4.3.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "jscpd": "^4.0.8",
    "lighthouse": "^13.0.3",
    "lint-staged": "^16.3.1",
    "madge": "^8.0.0",
    "playwright-lighthouse": "^4.0.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "vite": "^7.2.4"
  },
  "lint-staged": {
    "src/**/*.{js,jsx}": [
      "eslint",
      "jscpd --threshold 5",
      "madge --circular"
    ],
    "api/**/*.js": [
      "eslint"
    ],
    "*{src,api}/**/*.{js,jsx}": [
      "node tests/garbage-scanner.mjs"
    ]
  }
}